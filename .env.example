# ----------------------------------------------------------------------------
# Koryon - Ortam Değişkenleri Şablonu
# Bu dosyayı `.env.local` olarak kopyala ve değerleri kendi projenle doldur.
#   Windows PowerShell:  Copy-Item .env.example .env.local
#   macOS/Linux:         cp .env.example .env.local
# Railway'de bu değişkenleri Service > Variables sekmesinden ekle.
#
# NOT: Vite'ta tarayıcıya gönderilecek tüm değişkenler `VITE_` ön ekiyle
# başlamak ZORUNDA. `VITE_` öneki olmayan değişkenler bundle'a girmez.
# ----------------------------------------------------------------------------

# Supabase proje URL'i (Project Settings > API > Project URL)
VITE_SUPABASE_URL=https://rbejekpofukhpsyfisxf.supabase.co

# Supabase publishable / anon anahtarı (tarayıcıda kullanılabilir, public)
# Project Settings > API > Project API keys > anon / publishable
VITE_SUPABASE_ANON_KEY=sb_publishable_RBuma6AU5IJ5_OH3d8Fyrg_-CCyyQNF

# Service role anahtarı SADECE backend'de kullanılır - tarayıcıya ASLA gönderme.
# Bu projede şimdilik backend yok; ileride bir API/edge function eklersen
# orada (VITE_ öneki OLMADAN) tanımla.
# SUPABASE_SERVICE_ROLE_KEY=

# Railway preview/start için port. Railway PORT'u otomatik enjekte eder.
